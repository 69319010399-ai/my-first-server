// 1. เรียกใช้งาน Module ที่ชื่อว่า 'http' ซึ่งเปนระบบพื้นฐานของ Node.js สําหรับทําเซิรฟ เวอร
const http = require('http');

// 2. กําหนดช่องทาง (Port) ที่เซิรฟเวอรจะใชสื่อสาร โดยใหใชของที่ Cloud กําหนดมา(process.env.PORT) ถาไมมีใหใช 3000
const port = process.env.PORT || 3000;

// 3. สร้างเครื่องแม่ข่าย (Server) ที่คอยรับคําขอ (req) และตอบกลับ (res)
const server = http.createServer((req, res) => {

  // 3.1 ตั้งรหัสสถานะ 200 หมายถึง "ทํางานสําเร็จ (OK)"
  res.statusCode = 200;

  // 3.2 บอกบราว์เซอร์ของผู้ใช้ว่า สิ่งที่ส่งกลับไปคือไฟล์ข้อความแบบ HTML และรองรับภาษาไทย (utf-8)
  res.setHeader('Content-Type', 'text/html; charset=utf-8');

  // 3.3 ส่งข้อมูลหนาเว็บกลับไปหาผูใช (ตกแต่งสไตล์คอมพิวเตอร์และเพิ่ม Animation ขยับได้)
  res.end(`
    <!DOCTYPE html>
    <html lang="th">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Web Server - Tech Style</title>
        <style>
            /* ตั้งค่าพื้นหลังธีมมืดสไตล์ Hacker/Developer */
            body {
                background-color: #0a0e17;
                color: #00ffcc;
                font-family: 'Courier New', Courier, monospace;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
                margin: 0;
                overflow: hidden;
            }

            /* หน้าต่าง Terminal จำลอง */
            .terminal-box {
                background-color: #111827;
                border: 2px solid #00ffcc;
                border-radius: 12px;
                padding: 40px;
                box-shadow: 0 0 25px rgba(0, 255, 204, 0.3);
                text-align: center;
                max-width: 650px;
                width: 90%;
                
                /* ใส่อนิเมชันการลอยขึ้นลง */
                animation: floatAnimation 4s ease-in-out infinite;
            }

            /* ตกแต่งหัวข้อ */
            h1 {
                font-size: 24px;
                line-height: 1.6;
                color: #00ffcc;
                text-shadow: 0 0 10px rgba(0, 255, 204, 0.5);
                margin-top: 0;
            }

            /* ตกแต่งข้อความอธิบาย */
            p {
                color: #9ca3af;
                font-size: 16px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            /* จุดไฟสถานะเซิร์ฟเวอร์กะพริบได้ */
            .status-dot {
                width: 12px;
                height: 12px;
                background-color: #10b981;
                border-radius: 50%;
                box-shadow: 0 0 10px #10b981;
                
                /* ใส่อนิเมชันไฟกะพริบ */
                animation: pulseAnimation 1.5s infinite alternate;
            }

            /* โค้ดอนิเมชัน: กล่องลอยขึ้น-ลงนุ่มนวล */
            @keyframes floatAnimation {
                0% { transform: translateY(0px); }
                50% { transform: translateY(-15px); }
                100% { transform: translateY(0px); }
            }

            /* โค้ดอนิเมชัน: ไฟสถานะกะพริบและขยายขนาด */
            @keyframes pulseAnimation {
                0% { transform: scale(0.8); opacity: 0.5; box-shadow: 0 0 5px #10b981; }
                100% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 15px #10b981; }
            }
        </style>
    </head>
    <body>

        <div class="terminal-box">
            <h1>💻 สวัสดีค่ะ! นี่คือ Web Server ของ <br>[นางสาวศิริลักษณ์ อบนวล รหัสนักศึกษา 69319010399]</h1>
            <p>
                <span class="status-dot"></span> 
                เครื่องแม่ข่ายทํางานปกติบนระบบ Railway แล้วค่ะ!
            </p>
        </div>

    </body>
    </html>
  `);
});

// 4. สั่งใหเซิรฟเวอรเริ่มตนเปดรับฟงการเชื่อมตอตาม Port ที่กําหนดไว้
server.listen(port, () => {
  console.log(`Server is running! เครื่องแม่ข่ายเปิดทํางานแล้วที่ช่องทาง: ${port}`);
});
